      <th style="padding:8px 12px;text-align:left;border-bottom:2px solid #d0d7de;">Resolution</th>
      <th style="padding:8px 12px;text-align:left;border-bottom:2px solid #d0d7de;">Push Protection Bypassed</th>
    </tr>
    </thead>
    <tbody>
    {% for repo in repositories %}
      {% if repo.security_detail %}
        {% for alert in repo.security_detail.secret_scanning_alerts %}
    <tr>
      <td style="padding:8px 12px;border-bottom:1px solid #eee;">{{ repo.name }}</td>
      <td style="padding:8px 12px;border-bottom:1px solid #eee;">{{ alert.secret_type_display_name or alert.secret_type }}</td>
