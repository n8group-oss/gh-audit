    <br>
    <span>Generated: {{ metadata.generated_at }}</span>
  </div>
</footer>

<!-- ======================================================
     Inline JS — table sorting only, no external deps
     ====================================================== -->
<script>
(function () {
  "use strict";
  var table = document.getElementById("repo-table");
  if (!table) return;

  var headers = table.querySelectorAll("thead th");
  var sortCol = -1;
  var sortAsc = true;

  function cellValue(row, col) {
    var cell = row.cells[col];
    if (!cell) return "";
    var sortVal = cell.getAttribute("data-sort");
    if (sortVal !== null) return parseFloat(sortVal);
    return cell.textContent.trim().toLowerCase();
  }

  function sortRows(col) {
    var tbody = table.tBodies[0];
    var rows = Array.prototype.slice.call(tbody.rows);
    var asc = (col === sortCol) ? !sortAsc : true;

    rows.sort(function (a, b) {
      var av = cellValue(a, col);
      var bv = cellValue(b, col);
      if (typeof av === "number" && typeof bv === "number") {
        return asc ? av - bv : bv - av;
      }
      av = String(av); bv = String(bv);
      return asc ? av.localeCompare(bv) : bv.localeCompare(av);
    });

    rows.forEach(function (r) { tbody.appendChild(r); });

    headers.forEach(function (h) {
      h.classList.remove("sorted-asc", "sorted-desc");
    });
    headers[col].classList.add(asc ? "sorted-asc" : "sorted-desc");

    sortCol = col;
    sortAsc = asc;
  }

  headers.forEach(function (th, i) {
    th.addEventListener("click", function () { sortRows(i); });
  });
}());
</script>
</body>
</html>
