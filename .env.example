# gh-audit configuration
# See README.md for setup instructions

# --- Authentication (choose one) ---

# Option 1: GitHub App (recommended)
# GH_AUDIT_APP_ID=12345
# GH_AUDIT_PRIVATE_KEY_PATH=/path/to/key.pem
# GH_AUDIT_INSTALLATION_ID=67890

# Option 2: Personal Access Token
# GH_AUDIT_TOKEN=ghp_xxxxx

# --- Required ---
# GH_AUDIT_ORGANIZATION=myorg

# --- Optional ---
# GH_AUDIT_API_URL=https://api.github.com
# GH_AUDIT_TELEMETRY_DISABLED=1
