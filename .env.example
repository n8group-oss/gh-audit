# gh-audit configuration
# See README.md for setup instructions

# --- Authentication (choose one) ---

# Option 1: GitHub App (recommended)
# GH_SCANNER_APP_ID=12345
# GH_SCANNER_PRIVATE_KEY_PATH=/path/to/key.pem
# GH_SCANNER_INSTALLATION_ID=67890

# Option 2: Personal Access Token
# GH_SCANNER_TOKEN=ghp_xxxxx

# --- Required ---
# GH_SCANNER_ORGANIZATION=myorg

# --- Optional ---
# GH_SCANNER_API_URL=https://api.github.com
# GH_SCANNER_TELEMETRY_DISABLED=1
